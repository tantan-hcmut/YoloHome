# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/yolohome
# For local SQLite development, you can use:
# DATABASE_URL=sqlite:///yolohome.db

# Secret Key
SECRET_KEY=change_this_secret

# Adafruit IO Configuration
ADAFRUIT_IO_USER=your_adafruit_user
ADAFRUIT_IO_KEY=your_adafruit_key
ADAFRUIT_GROUP_KEY=yolohome

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Face++ Configuration
FACEPP_API_KEY=your_facepp_api_key
FACEPP_API_SECRET=your_facepp_api_secret
FACEPP_API_BASE=https://api-us.faceplusplus.com/facepp/v3
FACE_MATCH_THRESHOLD=75
FACE_STRICT_THRESHOLD=80
FACE_LIVENESS_MIN_POSE_DELTA=12
FACE_MAX_COMPARE_PROFILES=20
FACEPP_FACESET_OUTER_ID=yolohome_faces
